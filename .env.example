# Copia este archivo como .env y ajusta los valores para tu entorno local.
# NUNCA subas el archivo .env real al repositorio.

# --- PostgreSQL ---
# DB_HOST=localhost porque el backend corre en el host (mvn/mvnw); puerto externo mapeado 5433 -> interno 5432
DB_HOST=localhost
POSTGRES_DB=pfc_db
POSTGRES_USER=pfc_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# Genera tu propio secreto (no reutilices el de otro entorno): openssl rand -base64 48
JWT_SECRET=changeme-genera-un-secreto-base64-de-al-menos-32-bytes
JWT_EXPIRATION_MINUTES=15
